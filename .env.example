DATABASE_URL=
OPENAI_API_KEY=
CHROMA_DB_PATH=./chroma

# Web app (Next.js) → FastAPI base URL when using the in-app workflow
DATAPILOT_API_URL=http://127.0.0.1:8000

# --- Auth0 (SPA + API) ---
# Use the same Custom API identifier for audience on both FastAPI and Next.js.
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=
AUTH0_CALLBACK_URL=http://localhost:3000/api/auth/callback

NEXT_PUBLIC_AUTH0_DOMAIN=
NEXT_PUBLIC_AUTH0_CLIENT_ID=
NEXT_PUBLIC_AUTH0_AUDIENCE=
NEXT_PUBLIC_AUTH0_CALLBACK_URL=http://localhost:3000/api/auth/callback

# Optional: extra authorize scopes (e.g. My Account / Connected Accounts)
# NEXT_PUBLIC_AUTH0_ADDITIONAL_SCOPES=create:me:connected_accounts read:me:connected_accounts

# --- Auth0 Token Vault (POST /agent/slack) ---
# Custom API client with Token Vault grant, linked to the same API as AUTH0_AUDIENCE.
AUTH0_TOKEN_VAULT_CLIENT_ID=
AUTH0_TOKEN_VAULT_CLIENT_SECRET=
# Auth0 Slack connection name with Connected Accounts + Token Vault enabled
AUTH0_VAULT_SLACK_CONNECTION=slack

# Alerts without Token Vault (optional)
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# Slack Events API → POST /integrations/slack/events (channel messages to GLPI agent)
# SLACK_SIGNING_SECRET=
# SLACK_EVENTS_CHANNEL_IDS=C0123,C0456

# GLPI REST — optional ticket follow-up / status after webhook (apirest.php base URL, no trailing slash)
# GLPI_API_URL=https://glpi.example.com/apirest.php
# GLPI_APP_TOKEN=
# GLPI_USER_TOKEN=
# GLPI_WEBHOOK_ADD_FOLLOWUP=true
# GLPI_WEBHOOK_STATUS_ID=
# GLPI_WEBHOOK_EVENTS_MODE=open_only
